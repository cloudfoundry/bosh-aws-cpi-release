{
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "RequireTagsOnCreation",
        "Effect": "Deny",
        "Action": [
          "ec2:RunInstances",
          "ec2:CreateVolume"
        ],
        "Resource": [
          "arn:aws:ec2:*:*:instance/*",
          "arn:aws:ec2:*:*:volume/*"
        ],
        "Condition": {
          "Null": {
            "aws:RequestTag/BoshCPITest": "true"
          }
        }
      }
    ]
  }